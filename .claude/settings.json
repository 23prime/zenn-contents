{
  "permissions": {
    "allow": [
      "Bash(mise run:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git switch:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr create:*)",
      "Bash(mv:*)"
    ],
    "ask": [
      "Bash(git push --force:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "mise run fix 2>&1 || true",
            "statusMessage": "Running fix..."
          }
        ]
      }
    ]
  }
}
